// ECOPYE Pro Chantier - Schéma Prisma
// SQLite en dev (DATABASE_URL=file:./dev.db).
//
// NOTES IMPORTANTES :
// - Prisma n'autorise pas env() dans `provider` (erreur P1012) : le provider
//   doit être un littéral. Pour la prod PostgreSQL, basculer `provider` sur
//   "postgresql" (idéalement via un schema.prod.prisma dédié au déploiement).
// - SQLite ne supporte pas les enum natifs : les anciens enums sont stockés
//   en String. Les valeurs textuelles sont inchangées (ex: "OWNER",
//   "ESSAI", ...), donc le code applicatif reste compatible.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ================================
// VALEURS (anciennement enums, désormais String)
// ================================
// Role:               OWNER | ADMIN_COMPANY | TECHNICIAN | CLIENT | ECOPYE_ADMIN
// Trade:              PLOMBIER | CHAUFFAGISTE | ELECTRICIEN | RENOVATION_SALLE_DE_BAIN |
//                     MACON | PEINTRE | CARRELEUR | MENUISIER | MULTI_SERVICES | ENTREPRISE_GENERALE_BTP
// ClientType:         PARTICULIER | PROFESSIONNEL
// QuoteStatus:        BROUILLON | ENVOYE | VU | ACCEPTE | REFUSE | EXPIRE
// InvoiceType:        ACOMPTE | INTERMEDIAIRE | FINALE | AVOIR
// InvoiceStatus:      BROUILLON | ENVOYEE | EN_ATTENTE | PAYEE | EN_RETARD | ANNULEE
// PaymentStatus:      EN_ATTENTE | REUSSI | REFUSE | EXPIRE | REMBOURSE
// PaymentMethod:      VIREMENT | CHEQUE | CARTE_BANCAIRE | ESPECES | PRELEVEMENT
// ProjectStatus:      PREPARATION | EN_ATTENTE_ACOMPTE | EN_COURS | CONTROLE_QUALITE |
//                     RECEPTION_CLIENT | TERMINE | LITIGE_POTENTIEL | ANNULE
// ProjectStepStatus:  EN_ATTENTE | EN_COURS | TERMINE | VALIDE_CLIENT | PROBLEME
// RiskLevel:          FAIBLE | MOYEN | ELEVE | CRITIQUE
// PhotoCategory:      AVANT | PENDANT | APRES | PROBLEME | DETAIL | RECEPTION
// DocumentType:       ASSURANCE_DECENNALE | RESPONSABILITE_CIVILE | ATTESTATION_URSSAF |
//                     PV_RECEPTION | BON_INTERVENTION | BON_LIVRAISON | CONDITIONS_GENERALES |
//                     CHECKLIST_SECURITE | RAPPORT_CHANTIER | DOSSIER_LITIGE | AUTRE
// DocumentStatus:     VALIDE | EXPIRE_BIENTOT | EXPIRE | MANQUANT
// ScheduleStatus:     PLANIFIE | EN_COURS | TERMINE | ANNULE | REPORTE
// AiRequestType:      GENERER_DEVIS | REDIGER_RELANCE | RESUMER_CHANTIER | PREPARER_COMPTE_RENDU |
//                     ANALYSER_BUDGET | PREPARER_LITIGE | MESSAGE_WHATSAPP | EMAIL_PROFESSIONNEL | CHECKLIST_CHANTIER
// TicketStatus:       OUVERT | EN_COURS | RESOLU | FERME
// TicketPriority:     FAIBLE | NORMAL | ELEVE | URGENT
// SubscriptionPlan:   STARTER | PRO | PREMIUM | ENTREPRISE
// SubscriptionStatus: ACTIF | SUSPENDU | ANNULE | ESSAI

// ================================
// MODÈLES
// ================================

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("TECHNICIAN")
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  active       Boolean   @default(true)
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  photoUploads PhotoProof[]
  aiRequests   AiRequest[]
  tickets      SupportTicket[]
  scheduleEvents ScheduleEvent[]

  @@index([email])
  @@index([companyId])
}

model Company {
  id                    String    @id @default(cuid())
  name                  String
  ownerName             String
  siret                 String?   @unique
  trade                 String    @default("MULTI_SERVICES")
  address               String
  city                  String
  postalCode            String
  phone                 String
  email                 String
  vatNumber             String?
  insuranceNumber       String?
  insuranceExpiryDate   DateTime?
  logoUrl               String?
  monthlyRevenueTarget  Float     @default(0)
  active                Boolean   @default(true)
  onboardingCompleted   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users          User[]
  clients        Client[]
  quotes         Quote[]
  invoices       Invoice[]
  payments       Payment[]
  projects       Project[]
  documents      Document[]
  scheduleEvents ScheduleEvent[]
  technicians    Technician[]
  aiRequests     AiRequest[]
  tickets        SupportTicket[]
  subscription   Subscription?

  @@index([siret])
}

model Client {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  type        String     @default("PARTICULIER")
  firstName   String
  lastName    String
  companyName String?
  siret       String?
  vatNumber   String?
  email       String
  phone       String
  address     String
  city        String
  postalCode  String
  notes       String?
  trustScore  Int        @default(5)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  quotes    Quote[]
  invoices  Invoice[]
  payments  Payment[]
  projects  Project[]
  documents Document[]

  @@index([companyId])
  @@index([email])
}

model Quote {
  id                String      @id @default(cuid())
  companyId         String
  company           Company     @relation(fields: [companyId], references: [id])
  clientId          String
  client            Client      @relation(fields: [clientId], references: [id])
  number            String
  title             String
  description       String?
  status            String      @default("BROUILLON")
  subtotalHT        Float       @default(0)
  vatAmount         Float       @default(0)
  totalTTC          Float       @default(0)
  depositPercentage Float       @default(30)
  laborCost         Float       @default(0)
  materialCost      Float       @default(0)
  notes             String?
  termsAndConditions String?
  expiresAt         DateTime?
  sentAt            DateTime?
  viewedAt          DateTime?
  acceptedAt        DateTime?
  refusedAt         DateTime?
  publicToken       String?     @unique
  signerName        String?
  signerIp          String?
  signedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  lines     QuoteLine[]
  invoices  Invoice[]
  projects  Project[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([clientId])
}

model QuoteLine {
  id           String  @id @default(cuid())
  quoteId      String
  quote        Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  label        String
  description  String?
  quantity     Float   @default(1)
  unit         String  @default("forfait")
  unitPriceHT  Float   @default(0)
  vatRate      Float   @default(20)
  discount     Float   @default(0)
  totalHT      Float   @default(0)
  order        Int     @default(0)
  isLabor      Boolean @default(false)

  @@index([quoteId])
}

model Invoice {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  quoteId      String?
  quote        Quote?        @relation(fields: [quoteId], references: [id])
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id])
  number       String
  type         String        @default("FINALE")
  status       String        @default("BROUILLON")
  subtotalHT   Float         @default(0)
  vatAmount    Float         @default(0)
  totalTTC     Float         @default(0)
  amountPaid   Float         @default(0)
  retentionPct Float         @default(0)
  dueDate      DateTime?
  issuedAt     DateTime      @default(now())
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payments Payment[]
  lines    InvoiceLine[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([clientId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  label       String
  description String?
  quantity    Float   @default(1)
  unit        String  @default("forfait")
  unitPriceHT Float   @default(0)
  vatRate     Float   @default(20)
  totalHT     Float   @default(0)
  order       Int     @default(0)

  @@index([invoiceId])
}

model Payment {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  invoiceId     String?
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  amount        Float
  status        String        @default("EN_ATTENTE")
  method        String        @default("VIREMENT")
  paymentLink   String?
  qrCodeValue   String?
  receiptNumber String?
  notes         String?
  simulatedAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([invoiceId])
}

model Project {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id])
  title         String
  description   String?
  address       String
  city          String
  postalCode    String
  status        String        @default("PREPARATION")
  plannedBudget Float         @default(0)
  actualBudget  Float         @default(0)
  costMaterials   Float       @default(0)
  costLabor       Float       @default(0)
  costSubcontract Float       @default(0)
  costOverhead    Float       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  progress      Int           @default(0)
  riskLevel     String        @default("FAIBLE")
  notes         String?
  receptionAt        DateTime?
  receptionSignerName String?
  receptionNotes     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  steps      ProjectStep[]
  photos     PhotoProof[]
  invoices   Invoice[]
  documents  Document[]
  events     ScheduleEvent[]
  technicians ProjectTechnician[]
  reserves   Reserve[]

  @@index([companyId])
  @@index([clientId])
}

model Reserve {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([projectId])
}

model CatalogItem {
  id          String   @id @default(cuid())
  companyId   String
  label       String
  unit        String   @default("forfait")
  unitPriceHT Float    @default(0)
  vatRate     Float    @default(20)
  isLabor     Boolean  @default(false)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model ProjectStep {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String            @default("EN_ATTENTE")
  order       Int               @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  validatedByClient Boolean    @default(false)
  notes       String?

  @@index([projectId])
}

model ProjectTechnician {
  id           String     @id @default(cuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id])
  assignedAt   DateTime   @default(now())

  @@unique([projectId, technicianId])
}

model PhotoProof {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])
  category     String        @default("PENDANT")
  url          String
  caption      String?
  takenAt      DateTime      @default(now())
  createdAt    DateTime      @default(now())

  @@index([projectId])
}

model Document {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  projectId String?
  project   Project?       @relation(fields: [projectId], references: [id])
  clientId  String?
  client    Client?        @relation(fields: [clientId], references: [id])
  type      String         @default("AUTRE")
  title     String
  status    String         @default("VALIDE")
  fileUrl   String?
  expiresAt DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([companyId])
}

model Technician {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  email     String
  phone     String?
  trade     String   @default("MULTI_SERVICES")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduleEvents    ScheduleEvent[]
  assignedProjects  ProjectTechnician[]

  @@index([companyId])
}

model ScheduleEvent {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id])
  technicianId String?
  technician   Technician?    @relation(fields: [technicianId], references: [id])
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  status       String         @default("PLANIFIE")
  location     String?
  color        String?        @default("#3b82f6")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([companyId])
  @@index([projectId])
}

model AiRequest {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  type      String
  prompt    String
  response  String
  createdAt DateTime      @default(now())

  @@index([companyId])
}

model SupportTicket {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  subject   String
  status    String         @default("OUVERT")
  priority  String         @default("NORMAL")
  message   String
  response  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([companyId])
}

model Subscription {
  id                   String    @id @default(cuid())
  companyId            String    @unique
  company              Company   @relation(fields: [companyId], references: [id])
  plan                 String    @default("STARTER")
  status               String    @default("ESSAI")
  monthlyPrice         Float     @default(29)
  startedAt            DateTime  @default(now())
  endsAt               DateTime?
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([stripeCustomerId])
}
